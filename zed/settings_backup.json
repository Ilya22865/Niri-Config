{
    "outline_panel": {
        "dock": "left",
    },
    "collaboration_panel": {
        "dock": "left",
    },
    "git_panel": {
        "dock": "left",
    },
    "agent": {
        "dock": "right",
        "inline_assistant_model": {
            "provider": "zed.dev",
            "model": "gpt-5.2-codex",
            "enable_thinking": false,
        },
        "default_model": {
            "provider": "zed.dev",
            "model": "grok-4-fast-non-reasoning",
            "enable_thinking": false,
        },
        "favorite_models": [],
        "model_parameters": [],
    },
    "agent_servers": {
        "OpenCode": {
            "command": "opencode",
            "args": ["acp"],
        },
    },
    "icon_theme": {
        "mode": "light",
        "light": "Warm Charmed Icons",
        "dark": "Warm Charmed Icons",
    },
    "theme": {
        "mode": "dark",
        "light": "One Light",
        "dark": "Aura Dark",
    },
    "theme_overrides": {
        "Aura Dark": {
            "border.variant": "#15141b",
            "border": "#15141b",
            "title_bar.background": "#15141b",
            "panel.background": "#15141b",
            "panel.focused_border": "#15141b",
            "players": [
                {
                    "cursor": "#babdc0",
                },
            ],
            "syntax": {
                "comment": {
                    "font_style": "italic",
                },
                "comment.doc": {
                    "font_style": "italic",
                },
            },
        },
    },
    "experimental.theme_overrides": {
        "terminal.background": "#00000050",
        "title_bar.background": "#00000050",
        "panel.background": "#000000050",

        "text": "#FFFFFF",
        "text.muted": "#CCCCCC",
        "editor.foreground": "#FFFFFF",
        "terminal.foreground": "#FFFFFF",

        "background.appearance": "transparent",

        "background": "#00000050",
        "editor.background": "#00000050",
        "editor.gutter.background": "#00000050",
        "tab_bar.background": "#00000050",
    },
    "title_bar": {
        "show_onboarding_banner": false,
        "show_project_items": false,
        "show_branch_name": false,
        "show_user_menu": false,
    },
    "tab_bar": {
        "show": false,
    },
    "toolbar": {
        "quick_actions": false,
    },
    "status_bar": {
        "experimental.show": false,
    },
    "project_panel": {
        "dock": "right",
        "default_width": 400,
        "auto_fold_dirs": false,
        "starts_open": true,
        "scrollbar": {
            "show": "never",
        },
    },
    "file_finder": {
        "modal_max_width": "large",
    },
    "scrollbar": {
        "show": "never",
    },
    "gutter": {
        "min_line_number_digits": 0,
        "runnables": false,
    },
    "ui_font_family": "JetBrainsMono Nerd Font Mono",
    "ui_font_size": 20,
    "buffer_font_family": "JetBrainsMonoNL Nerd Font Mono",
    "buffer_font_size": 18,
    "vim_mode": true,
    "cursor_shape": "block",
    "selection_highlight": false,
    "drag_and_drop_selection": {
        "enabled": false,
    },
    "seed_search_query_from_cursor": "never",
    "current_line_highlight": "none",
    "show_whitespaces": "none",
    "tab_size": 4,
    "show_completion_documentation": false,
    "autosave": {
        "after_delay": {
            "milliseconds": 1000,
        },
    },
    "extend_comment_on_newline": false,
    "horizontal_scroll_margin": 1,
    "vertical_scroll_margin": 1,
    "when_closing_with_no_tabs": "keep_window_open",
    "close_on_file_delete": true,
    "restore_on_file_reopen": false,
    "restore_on_startup": "empty_tab",
    "session": {
        "restore_unsaved_buffers": false,
    },
    "centered_layout": {
        "right_padding": 0.15,
        "left_padding": 0.15,
    },
    "lsp": {
        "omnisharp": {
            "initialization_options": {
                "enableMsBuildLoadProjectsOnDemand": false,
                "enableRoslynAnalyzers": true,
                "organizeImportsOnFormat": true,
            },
            "settings": {
                "omnisharp": {
                    "enableImportCompletion": true,
                    "sdk": {
                        "includePrereleases": true,
                    },
                },
            },
        },
    },
}
