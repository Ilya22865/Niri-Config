{
  "layer": "top",
  "position": "top",
  "spacing": 0,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "height": 34,
  "modules-left": [
    "niri/workspaces",
    "custom/theme-toggle",
    "custom/cava"
  ],
  "modules-center": [
    "clock"
  ],
  "modules-right": [
    "niri/language",
    "tray",
    "wireplumber",
    "idle_inhibitor",
    "custom/tlp",
    "battery"
  ],
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "Keep awake",
      "deactivated": "Keep awake"
    }
  },
  "custom/theme-toggle": {
    "format": "Switch Theme",
    "tooltip": "╨κ╨╝╨╡╨╜╨╕╤Γ╤Ν ╤Γ╨╡╨╝╤Δ (╨λ╤Σ╨╝╨╜╨░╤Π έΗΦ ╨κ╨▓╨╡╤Γ╨╗╨░╤Π)",
    "on-click": "$HOME/.config/waybar/style.sh",
    "return-type": "string"
  },
  "custom/cava": {
    "format": "{}",
    "exec": "~/.config/waybar/cava.sh"
  },
  "wlr/taskbar": {
    "format": "{icon}",
    "on-click": "activate",
    "on-click-right": "fullscreen",
    "icon-theme": "WhiteSur",
    "icon-size": 25,
    "tooltip-format": "{title}"
  },
  "niri/workspaces": {
    "on-click": "activate",
    "format": "{icon}",
    "format-icons": {
      "default": "έβκ",
      "1": "έεθ",
      "2": "έβξ ",
      "3": "ΏζΕκ",
      "4": "έζΗ",
      "5": "έζμ",
      "6": "6",
      "7": "7",
      "8": "8",
      "9": "9",
      "active": "≤▒Υ╗",
      "urgent": "≤▒Υ╗"
    },
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": [],
      "5": []
    }
  },
  "memory": {
    "interval": 5,
    "format": "≤░Ξδ {}%",
    "max-length": 10
  },
  "tray": {
    "spacing": 10
  },
  "clock": {
    "tooltip-format": "{calendar}",
    "format-alt": "Ός░  {:%a, %d %b %Y}",
    "format": "ΎΡ║  {:%H:%M}"
  },
  "network": {
    "format-wifi": "{icon}",
    "format-icons": [
      "≤░νψ",
      "≤░νθ",
      "≤░νλ",
      "≤░νξ",
      "≤░νρ"
    ],
    "format-ethernet": "≤░ΑΓ",
    "format-alt": "≤▒δΘ",
    "format-disconnected": "≤░Ψς",
    "tooltip-format-wifi": "{icon} {essid}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-ethernet": "≤░ΑΓ  {ifname}\nέΘμ{bandwidthDownBytes}  έΘκ{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "on-click": "~/.config/rofi/wifi/wifi.sh &",
    "on-click-right": "~/.config/rofi/wifi/wifinew.sh &",
    "interval": 5,
    "nospacing": 1
  },
  "custom/tlp": {
    "exec": "$HOME/.config/waybar/tlp.sh",
    "interval": 10,
    "return-type": "json",
  },
  "wireplumber": {
    "format": "{icon}",
    "format-bluetooth": "≤░Γ░",
    "nospacing": 1,
    "tooltip-format": "Volume : {volume}%",
    "format-muted": "≤░ζθ",
    "format-icons": {
      "headphone": "ΎΑξ",
      "default": [
        "≤░ΨΑ",
        "≤░Χ╛",
        "ΎΑρ"
      ]
    },
    "on-click": "pamixer -t",
    "scroll-step": 1
  },
  "custom/logo": {
    "format": " ΎΝΔ ",
    "tooltip": false,
    "on-click": "~/.config/rofi/launchers/misc/launcher.sh &"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-icons": {
      "charging": [
        "≤░λε",
        "≤░ΓΗ",
        "≤░ΓΘ",
        "≤░ΓΙ",
        "≤░λζ",
        "≤░ΓΚ",
        "≤░λη",
        "≤░ΓΛ",
        "≤░ΓΜ",
        "≤░ΓΖ"
      ],
      "default": [
        "≤░Β║",
        "≤░Β╗",
        "≤░Β╝",
        "≤░Β╜",
        "≤░Β╛",
        "≤░Β┐",
        "≤░ΓΑ",
        "≤░ΓΒ",
        "≤░ΓΓ",
        "≤░Β╣"
      ]
    },
    "format-full": "Charged ΎΔπ",
    "interval": 5,
    "states": {
      "warning": 20,
      "critical": 10
    },
    "tooltip": false
  },
  "custom/power": {
    "format": "≤░νΗ",
    "tooltip": false,
    "on-click": "wlogout"
  },
  "niri/language": {
    "format": "Lang: {short}",
    "format-us": "US",
    "format-rus": "RU"
  }
}
