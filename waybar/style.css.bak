* {
  border: none;
  border-radius: 0;
  min-height: 0;
  font-family: JetBrainsMono Nerd Font;
  font-size: 14px;
}

window#waybar {
  background-color: #1C1C1C;
  transition-property: background-color;
  transition-duration: 0.5s;
}

window#waybar.hidden {
  opacity: 0.5;
}

#workspaces {
  background-color: transparent;
}

#workspaces button {
  all: initial;
  /* Remove GTK theme values (waybar #1351) */
  min-width: 0;
  /* Fix weird spacing in materia (waybar #450) */
  box-shadow: inset 0 -3px transparent;
  /* Use box-shadow instead of border so the text isn't offset */
  padding: 6px 18px;
  margin: 6px 3px;
  border-radius: 5px;
  background-color: #F9F7F2;
  color: #1c1c1c;
  font-size: 16px;
}

#workspaces button.active {
  color: #F9F7F2;
  background-color: #1c1c1c;

}

#workspaces button:hover {
  box-shadow: inherit;
  text-shadow: inherit;
  color: #1c1c1c;
  background-color: #F9F7F2;
}

#workspaces button.urgent {
  background-color: #f38ba8;
}

#memory,
#custom-power,
#battery,
#backlight,
#wireplumber,
#network,
#clock,
#tray,
#idle_inhibitor,
#language,
#custom-cava,
#custom-theme-toggle,
#custom-tlp {
  border-radius: 4px;
  margin: 6px 3px;
  padding: 6px 12px;
  font-size: 16;
}

#custom-cava {
  color: #F9F7F2;
  background-color: transparent;
}

#tray {
  background-color: transparent;
  margin: 6px 3px;
  padding: 6px 12px;
  color: #000;
}

#custom-tlp {
  background-color: #F9F7F2;
  color: #1c1c1c;
}

#custom-tlp.tlp-bat {
  background-color: #bdd984;
}

#custom-power {
  margin-right: 6px;
}

#custom-logo {
  padding-right: 7px;
  padding-left: 7px;
  margin-left: 5px;
  font-size: 15px;
  border-radius: 8px 0px 0px 8px;
  color: #1793d1;
}

#memory {
  background-color: #F9F7F2;
  color: #1c1c1c;
}

#battery {
  background-color: #f38ba8;
  color: #1c1c1c;
}

#battery.warning,
#battery.critical,
#battery.urgent {
  background-color: #ff0000;
  color: #FFFF00;
}

#battery.charging {
  background-color: #a6e3a1;
  color: #181825;
}

#idle_inhibitor {
  background-color: transparent;
  color: #F9F7F2;
  text-decoration: line-through;
}

#idle_inhibitor.activated {
  background-color: #F9F7F2;
  color: #1c1c1c;
  text-decoration: none;
}

#wireplumber {
  background-color: #1c1c1c;
  color: #F9F7F2;
  padding-right: 20px;
}

#language.us {
  background-color: #F9F7F2;
  color: #1c1c1c;
}

#language.ru {
  background-color: #1c1c1c;
  color: #F9F7F2;
}

#custom-theme-toggle {
  background-color: #F9F7F2;
  color: #1c1c1c;
}

#network {
  background-color: #1c1c1c;
  padding-right: 17px;
  color: #F9F7F2;
}

#clock {
  font-family: JetBrainsMono Nerd Font;
  background-color: transparent;
  color: #F9F7F2;
  font-weight: bold;
  margin-right: 150px;
}

tooltip {
  border-radius: 8px;
  padding: 15px;
  background-color: #131822;
}

tooltip label {
  padding: 5px;
  background-color: #131822;
}
